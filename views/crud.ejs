<% var mode = typeof mode !== 'undefined' ? mode : 'list'; %>
<% var item = typeof item !== 'undefined' ? item : null; %>
<% var error = typeof error !== 'undefined' ? error : null; %>
<% var search = typeof search !== 'undefined' ? search : {}; %>
<% var searchQuery = typeof searchQuery !== 'undefined' ? searchQuery : ''; %>
<% var items = typeof items !== 'undefined' ? items : []; %>
<% var currentPage = typeof currentPage !== 'undefined' ? currentPage : 1; %>
<% var totalPages = typeof totalPages !== 'undefined' ? totalPages : 0; %>

<!-- Modal: Create / Edit -->
<div class="modal fade" id="formModal" tabindex="-1">
  <div class="modal-dialog modal-lg">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title" id="formModalTitle"><%= mode === 'edit' ? '编辑' : '新建' %> - <%= config.title %></h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" id="crudForm" action="<%= mode === 'edit' ? '/' + config.menuKey + '/' + item[config.idField] : '/' + config.menuKey %>">
        <div class="modal-body">
          <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
          <% for (const f of config.fields) { %>
            <div class="mb-3">
              <label class="form-label"><%= f.label %> <% if (f.required) { %><span class="text-danger">*</span><% } %></label>
              <% if (f.type === 'select') { %>
                <select name="<%= f.name %>" class="form-select">
                  <option value="">请选择</option>
                  <% for (const opt of f.options) { %>
                    <option value="<%= opt %>" <%= item && item[f.name] === opt ? 'selected' : '' %>><%= opt %></option>
                  <% } %>
                </select>
              <% } else if (f.type === 'textarea') { %>
                <textarea name="<%= f.name %>" class="form-control" rows="3"><%= item ? (item[f.name] || '') : '' %></textarea>
              <% } else if (f.type === 'number') { %>
                <input type="number" name="<%= f.name %>" class="form-control"
                       step="any" value="<%= item ? (item[f.name] || 0) : '' %>"
                       <% if (f.computed) { %> readonly <% } %>>
              <% } else if (f.type === 'date') { %>
                <input type="date" name="<%= f.name %>" class="form-control"
                       value="<%= item && item[f.name] ? String(item[f.name]).slice(0,10) : '' %>">
              <% } else if (f.type === 'datetime-local') { %>
                <input type="datetime-local" name="<%= f.name %>" class="form-control"
                       value="<%= item && item[f.name] ? String(item[f.name]).slice(0,16) : '' %>">
              <% } else { %>
                <input type="text" name="<%= f.name %>" class="form-control"
                       value="<%= item ? (item[f.name] || '') : '' %>"
                       <% if (f.required) { %> required <% } %>>
              <% } %>
            </div>
          <% } %>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
          <button type="submit" class="btn btn-primary">确定</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Delete confirm modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">确认删除</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body">
        <p>确定要删除该条数据吗？此操作不可恢复。</p>
      </div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
        <form id="deleteForm" method="POST" style="display:inline;">
          <button type="submit" class="btn btn-danger">确认删除</button>
        </form>
      </div>
    </div>
  </div>
</div>

<!-- Page content -->
<h4 class="mb-3"><%= config.title %></h4>

<!-- Search bar -->
<div class="card mb-3">
  <div class="card-body py-2">
    <form class="row g-2 align-items-end" method="GET" action="/<%= config.menuKey %>">
      <% for (const sf of config.searchFields) { %>
        <% const field = config.fields.find(function(f){ return f.name === sf; }); %>
        <div class="col-auto">
          <label class="form-label small mb-0"><%= field ? field.label : sf %></label>
          <input type="text" name="<%= sf %>" class="form-control form-control-sm"
                 value="<%= search[sf] || '' %>" placeholder="搜索...">
        </div>
      <% } %>
      <div class="col-auto">
        <button type="submit" class="btn btn-primary btn-sm">搜索</button>
        <a href="/<%= config.menuKey %>" class="btn btn-outline-secondary btn-sm">重置</a>
      </div>
    </form>
  </div>
</div>

<!-- Toolbar -->
<div class="d-flex justify-content-between align-items-center mb-3">
  <span class="text-muted">
    共 <strong><%= items.length %></strong> 条记录
    <% if (totalPages > 0) { %>/ 第 <%= currentPage %>/<%= totalPages %> 页<% } %>
  </span>
  <button class="btn btn-primary btn-sm" onclick="openCreateForm()">
    <i class="bi bi-plus-lg me-1"></i>新建
  </button>
</div>

<!-- Data table -->
<div class="card">
  <div class="table-responsive">
    <table class="table table-hover table-sm mb-0">
      <thead class="table-light">
        <tr>
          <% for (const col of config.listColumns) { %>
            <% const field = config.fields.find(function(f){ return f.name === col; }); %>
            <th><%= field ? field.label : col %></th>
          <% } %>
          <th style="width:140px;">操作</th>
        </tr>
      </thead>
      <tbody>
        <% if (items.length === 0) { %>
          <tr><td colspan="<%= config.listColumns.length + 1 %>" class="text-center text-muted py-4">暂无数据</td></tr>
        <% } else { %>
          <% for (const item of items) { %>
            <tr>
              <% for (const col of config.listColumns) { %>
                <% const val = item[col]; %>
                <td>
                  <% if (val === null || val === undefined || val === '') { %>
                    <span class="text-muted">-</span>
                  <% } else if (col.indexOf('score') >= 0 || col.indexOf('Score') >= 0) { %>
                    <span class="badge bg-<%= val >= 70 ? 'success' : val >= 40 ? 'warning' : 'danger' %>"><%= val %></span>
                  <% } else if (col === 'status') { %>
                    <span class="badge bg-<%= val === 'draft' || val === 'pending' ? 'secondary' : val === 'active' || val === 'handled' || val === 'sent' || val === 'resolved' || val === 'completed' ? 'success' : 'warning' %>"><%= val %></span>
                  <% } else if (col === 'risk_level') { %>
                    <span class="badge bg-<%= val === 'high' ? 'danger' : val === 'medium' ? 'warning' : 'success' %>"><%= val %></span>
                  <% } else if (col === 'push_status') { %>
                    <span class="badge bg-<%= val === 'draft' ? 'secondary' : val === 'sent' ? 'success' : 'danger' %>"><%= val %></span>
                  <% } else if (String(val).length > 40) { %>
                    <span title="<%= val %>"><%= String(val).slice(0, 40) %>...</span>
                  <% } else { %>
                    <%= val %>
                  <% } %>
                </td>
              <% } %>
              <td>
                <a href="/<%= config.menuKey %>/<%= item[config.idField] %>/edit"
                   class="btn btn-outline-primary btn-sm me-1">编辑</a>
                <button class="btn btn-outline-danger btn-sm"
                        onclick="confirmDelete('<%= config.menuKey %>', '<%= item[config.idField] %>')">删除</button>
              </td>
            </tr>
          <% } %>
        <% } %>
      </tbody>
    </table>
  </div>
  <% if (totalPages > 1) { %>
    <div class="card-footer d-flex justify-content-end">
      <%- include('partials/pagination', { baseUrl: '/' + config.menuKey, currentPage: currentPage, totalPages: totalPages, searchQuery: searchQuery }) %>
    </div>
  <% } %>
</div>

<script>
  function openCreateForm() {
    document.querySelectorAll('#formModal input:not([readonly]), #formModal textarea, #formModal select').forEach(function(el) {
      if (el.type === 'number') el.value = '0';
      else if (el.tagName === 'SELECT') el.selectedIndex = 0;
      else el.value = '';
    });
    document.getElementById('crudForm').action = '/<%= config.menuKey %>';
    document.getElementById('formModalTitle').textContent = '新建 - <%= config.title %>';
    new bootstrap.Modal(document.getElementById('formModal')).show();
  }

  function confirmDelete(menuKey, id) {
    document.getElementById('deleteForm').action = '/' + menuKey + '/' + id + '/delete';
    new bootstrap.Modal(document.getElementById('deleteModal')).show();
  }

  // Auto-open modal if in create/edit mode
  <% if (mode === 'create' || mode === 'edit') { %>
    document.addEventListener('DOMContentLoaded', function() {
      new bootstrap.Modal(document.getElementById('formModal')).show();
    });
  <% } %>
</script>
