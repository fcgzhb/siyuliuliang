<h4 class="mb-3">权限分配</h4>

<!-- Create role -->
<div class="card mb-3">
  <div class="card-header bg-light fw-bold">
    <i class="bi bi-plus-circle me-1"></i>新建角色
  </div>
  <div class="card-body">
    <form method="POST" action="/permissions" class="row g-2 align-items-end">
      <div class="col-auto">
        <input type="text" name="role_name" class="form-control form-control-sm" placeholder="角色名称" required>
      </div>
      <div class="col-auto flex-grow-1">
        <input type="text" name="role_description" class="form-control form-control-sm" placeholder="角色描述">
      </div>
      <div class="col-auto">
        <button type="submit" class="btn btn-primary btn-sm">创建</button>
      </div>
    </form>
  </div>
</div>

<!-- Roles list -->
<% for (const role of roles) { %>
<div class="card mb-3">
  <div class="card-header d-flex justify-content-between align-items-center">
    <span class="fw-bold">
      <i class="bi bi-shield-lock me-1"></i><%= role.role_name %>
      <span class="badge bg-<%= role.status ? 'success' : 'secondary' %>"><%= role.status ? '启用' : '禁用' %></span>
    </span>
    <div>
      <button class="btn btn-outline-primary btn-sm" onclick="editRole(<%= role.id %>, '<%= role.role_name %>', '<%= role.role_description %>', <%= role.status %>)">
        <i class="bi bi-pencil me-1"></i>编辑
      </button>
      <button class="btn btn-outline-danger btn-sm" onclick="deleteRole(<%= role.id %>, '<%= role.role_name %>')">
        <i class="bi bi-trash me-1"></i>删除
      </button>
    </div>
  </div>
  <div class="card-body">
    <p class="text-muted small mb-2"><%= role.role_description || '暂无描述' %></p>
    <p class="text-muted small mb-2">创建时间: <%= role.created_at %></p>

    <!-- Members -->
    <h6 class="mt-3"><i class="bi bi-people me-1"></i>角色成员</h6>
    <div class="mb-2">
      <form method="POST" action="/permissions/<%= role.id %>/members" class="row g-2 align-items-end">
        <div class="col-auto">
          <select name="user_id" class="form-select form-select-sm" required>
            <option value="">选择用户...</option>
            <% for (const u of allUsers) { %>
              <option value="<%= u.id %>"><%= u.username %> (<%= u.display_name %>)</option>
            <% } %>
          </select>
        </div>
        <div class="col-auto">
          <button type="submit" class="btn btn-success btn-sm">添加成员</button>
        </div>
      </form>
    </div>
    <% var members = roleMembers[role.id] || []; %>
    <% if (members.length === 0) { %>
      <p class="text-muted small">暂无成员</p>
    <% } else { %>
      <div class="d-flex flex-wrap gap-2">
        <% for (const m of members) { %>
          <span class="badge bg-light text-dark border d-flex align-items-center">
            <%= m.display_name || m.username %>
            <form method="POST" action="/permissions/<%= role.id %>/members/<%= m.id %>/remove" style="display:inline;">
              <button type="submit" class="btn-close btn-close-sm ms-1" title="移除"></button>
            </form>
          </span>
        <% } %>
      </div>
    <% } %>
  </div>
</div>
<% } %>

<% if (roles.length === 0) { %>
<div class="text-center text-muted py-5">
  <i class="bi bi-shield-lock" style="font-size:3rem;"></i>
  <p class="mt-2">暂无角色，请创建新角色</p>
</div>
<% } %>

<!-- Edit modal -->
<div class="modal fade" id="editModal" tabindex="-1">
  <div class="modal-dialog">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">编辑角色</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <form method="POST" id="editForm">
        <div class="modal-body">
          <input type="hidden" name="status" id="editStatus">
          <div class="mb-3">
            <label class="form-label">角色名称</label>
            <input type="text" name="role_name" id="editName" class="form-control" required>
          </div>
          <div class="mb-3">
            <label class="form-label">角色描述</label>
            <textarea name="role_description" id="editDesc" class="form-control" rows="3"></textarea>
          </div>
          <div class="mb-3">
            <label class="form-check">
              <input type="checkbox" id="editStatusCheck" class="form-check-input" checked>
              <span class="form-check-label">启用</span>
            </label>
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
          <button type="submit" class="btn btn-primary">确定</button>
        </div>
      </form>
    </div>
  </div>
</div>

<!-- Delete confirm modal -->
<div class="modal fade" id="deleteModal" tabindex="-1">
  <div class="modal-dialog modal-sm">
    <div class="modal-content">
      <div class="modal-header">
        <h5 class="modal-title">确认删除</h5>
        <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
      </div>
      <div class="modal-body"><p id="deleteMsg">确定要删除吗？</p></div>
      <div class="modal-footer">
        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">取消</button>
        <form id="deleteForm" method="POST"><button type="submit" class="btn btn-danger">确认删除</button></form>
      </div>
    </div>
  </div>
</div>

<script>
function editRole(id, name, desc, status) {
  document.getElementById('editForm').action = '/permissions/' + id;
  document.getElementById('editName').value = name;
  document.getElementById('editDesc').value = desc;
  document.getElementById('editStatusCheck').checked = !!status;
  new bootstrap.Modal(document.getElementById('editModal')).show();
  document.getElementById('editForm').onsubmit = function() {
    document.getElementById('editStatus').value = document.getElementById('editStatusCheck').checked ? 1 : 0;
  };
}

function deleteRole(id, name) {
  document.getElementById('deleteMsg').textContent = '确定要删除角色 "' + name + '" 吗？该角色下的成员关系也会被删除。';
  document.getElementById('deleteForm').action = '/permissions/' + id + '/delete';
  new bootstrap.Modal(document.getElementById('deleteModal')).show();
}
</script>
